# Supabase (required for CMS + forms)
WDA_SUPABASE_URL=https://your-project.supabase.co
WDA_SUPABASE_ANON_KEY=your-anon-key
WDA_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# NextAuth admin login (required for /admin)
NEXTAUTH_SECRET=generate-a-long-random-string
NEXTAUTH_URL=http://localhost:3000

# Optional bootstrap admin (until users exist in Supabase)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# Optional AI assistant keys
GOOGLE_AI_API_KEY=
ANTHROPIC_API_KEY=
